# PAKT Protocol — Environment Configuration
# Copy to .env and fill in your Testnet-12 private keys

# Required for live testnet deployment
PAKT_TESTNET_BUYER_KEY=
PAKT_TESTNET_SELLER_KEY=

# Optional overrides
# PAKT_TESTNET_ARB_KEY=
# PAKT_RPC_URL=wss://testnet-12.kaspa.org/wrpc/v1
# PAKT_LOCK_AMOUNT=1000000000
# PAKT_TIMEOUT_DAA_DELTA=120
